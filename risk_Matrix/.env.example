# JWT Configuration — generate a secure random secret (minimum 32 bytes)
JWT_SECRET=your_jwt_secret_here_make_it_long_and_random
JWT_EXPIRATION_MS=86400000
JWT_PUBLIC_EXPIRATION_MS=3600000

# Cookie — set to true when serving over HTTPS (production)
COOKIE_SECURE=false

# Trusted reverse-proxy IPs for X-Forwarded-For (comma-separated)
TRUSTED_PROXIES=127.0.0.1,::1

# Default admin account created on first startup (change in production!)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
